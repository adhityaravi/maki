# Flat secrets file for SOPS TF provider.
# To create the encrypted version:
#   1. Copy this to secrets.yaml
#   2. Fill in actual values (from: sops -d ../manifests/secrets.enc.yaml + kubectl)
#   3. cd infra && sops -e secrets.yaml > secrets.enc.yaml
#   4. rm secrets.yaml
#
# All values are shared across clusters except graph (sushitrash + kawaiikuma only).

# Claude OAuth (shared across all pods that need LLM access)
claude_oauth_token: ""

# Discord bot token (ears leader only, but secret exists everywhere)
discord_bot_token: ""

# NATS auth token (shared across all clusters)
nats_token: ""

# PostgreSQL credentials
vault_password: ""
vault_postgres_password: ""

# Neo4j graph auth (recall connects to graph)
graph_auth_password: ""

# Neo4j graph secret (NEO4J_AUTH format: neo4j/<password>)
graph_secret_password: ""

# GitHub App credentials (cortex + stem)
github_app_id: ""
github_installation_id: ""
github_private_key_pem: ""
